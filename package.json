{
  "name": "clin",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npm --prefix web run dev",
    "dev:stop": "npm --prefix web run dev:stop",
    "dev:clean": "npm --prefix web run dev:clean",
    "build": "npm --prefix web run build",
    "build:desktop:web": "npm --prefix web run build:desktop",
    "build:desktop:prepare": "node scripts/prepare-electron-app.mjs",
    "build:desktop": "npm run build:desktop:web && npm run build:desktop:prepare",
    "dist:desktop": "npm run build:desktop && electron-builder",
    "dist:desktop:win": "npm run build:desktop && electron-builder --win portable zip",
    "dist:desktop:mac": "npm run build:desktop && electron-builder --mac zip",
    "dist:extension": "node scripts/zip-extension.mjs",
    "desktop:start": "electron .",
    "start": "npm --prefix web run start",
    "lint": "npm --prefix web run lint",
    "db:repair": "npm --prefix web run db:repair",
    "db:generate": "npm --prefix web run db:generate",
    "db:push": "npm --prefix web run db:push",
    "db:studio": "npm --prefix web run db:studio"
  },
  "devDependencies": {
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.clin.desktop",
    "productName": "Clin",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop-app",
        "to": "desktop-app",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ]
    },
    "portable": {
      "artifactName": "Clin-${version}-windows-portable.${ext}"
    }
  }
}
