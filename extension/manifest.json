{
  "manifest_version": 3,
  "name": "Clin Capture",
  "version": "0.1.0",
  "description": "Manual capture of visible LinkedIn data into your local Clin app. No automated LinkedIn actions.",
  "action": {
    "default_title": "Clin",
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
