{
  "manifest_version": 3,
  "name": "Clin Capture",
  "version": "0.2.25",
  "description": "Capture LinkedIn data into your local Clin app. White-and-blue Clin UI with optional paced outreach when enabled in Settings.",
  "action": {
    "default_title": "Clin",
    "default_icon": {
      "16": "icons/Clin_Logo_Small.png",
      "32": "icons/Clin_Logo_Small.png",
      "48": "icons/Clin_Logo_Small.png",
      "128": "icons/Clin_Logo_Small.png"
    }
  },
  "icons": {
    "16": "icons/Clin_Logo_Small.png",
    "32": "icons/Clin_Logo_Small.png",
    "48": "icons/Clin_Logo_Small.png",
    "128": "icons/Clin_Logo_Small.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "alarms",
    "sidePanel",
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "windows",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
