{
  "manifest_version": 3,
  "name": "Clin Capture",
  "version": "0.2.13",
  "description": "Capture visible LinkedIn data into your local Clin app. Optional slow hygiene runner (Settings) can open queued profiles for refresh only — no messaging or bulk actions.",
  "action": {
    "default_title": "Clin"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "alarms",
    "sidePanel",
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
