# Clin web — copy to .env.local (never commit secrets)
#
# Set only what you use. Restart dev after changes: npm run dev

# --- LLM: OVH / OpenAI-compatible cloud ---
# LLM_PROVIDER=openai_compatible
# OVH_AI_ENDPOINTS_ACCESS_TOKEN=
# OVH_AI_UNIFIED_MODEL_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
# OVH_AI_ENDPOINTS_MODEL_URL=https://mistral-7b-instruct-v0-3.endpoints.kepler.ai.cloud.ovh.net/api/openai_compat/v1
# OVH_AI_CHAT_URL=
# OVH_AI_ORCHESTRATOR_MODEL=Mistral-Small-3.2-24B-Instruct-2506
# LLM_MODEL=Mistral-Small-3.2-24B-Instruct-2506

# --- LLM: local Ollama ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:8b

# --- Post images: Stability SD3, then OVH SDXL if credits run out (Nemrut-style) ---
# STABILITY_API_KEY=
# STABILITY_SD3_URL=https://api.stability.ai/v2beta/stable-image/generate/sd3
# STABILITY_SD3_MODEL=sd3.5-large
# OVH fallback (free SDXL — uses same token as LLM):
# OVH_SDXL_TEXT2IMAGE_URL=https://stable-diffusion-xl.endpoints.kepler.ai.cloud.ovh.net/api/text2image

# CLIN_DB_PATH=

# --- Editorial trends (optional) ---
# TAVILY_API_KEY=

# --- Editorial job tick (optional, when calling POST /api/branding/jobs/tick remotely) ---
# BRANDING_TICK_SECRET=
